def policz_pierwiastki(a,b,c):
delta =b**2 - 4*a*c
if delta < 0:
return "brak rozwiązań rzeczywistych"
elif delta == 0:
x = -b / (2*a)
retun f"jedno rozwiązanie: x = {x}"
else:
x1 = (-b - delta**0.5) / (2*a)
x2 = (-b + delta**0.5) / (2*a)
return f"x₁ = {x1:2f}, x₂ = {x2:.2f}"
print("Obliczam delty i pierwiastki")
print(policz_pierwiastki(1, -5, 6))

